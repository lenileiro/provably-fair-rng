  "description": "Provably fair RNG service with HMAC-SHA256 server-seed commitment and client-side verifier",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node src/api/server.ts",
